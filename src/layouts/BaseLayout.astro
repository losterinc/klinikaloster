---
import '@/styles/global.css';
import { type Locale, useTranslations, withBase } from '@/lib/i18n';
import { getSettings } from '@/lib/content';
import { clinicJsonLd } from '@/lib/seo';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Seo from '@/components/Seo.astro';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** Equivalent page path in each locale, for hreflang + language switcher. */
  alternates: Record<Locale, string>;
  ogImage?: string;
}

const { locale, title, description, alternates, ogImage } = Astro.props;
const t = useTranslations(locale);
const settings = await getSettings(locale);

const siteUrl = (Astro.site ?? new URL('http://localhost:4321')).href.replace(/\/$/, '');
const jsonLd = clinicJsonLd(settings, siteUrl, locale);
const fullTitle = title.includes(settings.clinicName) ? title : `${title} · ${settings.clinicName}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <Seo
      title={fullTitle}
      description={description}
      locale={locale}
      alternates={alternates}
      ogImage={ogImage}
      jsonLd={jsonLd}
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:shadow">
      {t('skip.content')}
    </a>
    <Header locale={locale} clinicLogoImage={settings.logo} clinicName={settings.clinicName} alternates={alternates} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} settings={settings} />
  </body>
</html>
