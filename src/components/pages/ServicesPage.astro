---
import { type Locale, useTranslations, localePath, withBase, LOCALES } from '@/lib/i18n';
import { getLocalizedEntry, getAll } from '@/lib/content';
import BaseLayout from '@/layouts/BaseLayout.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const page = await getLocalizedEntry('pages', 'services', locale);
if (!page) throw new Error(`Missing pages/services.${locale}.md`);

const services = await getAll('services');

// group by category, preserving order
const groups = new Map<string, typeof services>();
for (const s of services) {
  const key = s.data.category ?? '';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(s);
}

const alternates = Object.fromEntries(LOCALES.map((l) => [l, localePath(l, 'services')])) as Record<
  Locale,
  string
>;
---

<BaseLayout
  locale={locale}
  title={page.data.seo?.title ?? page.data.title}
  description={page.data.seo?.description ?? ''}
  alternates={alternates}
>
  <section class="relative isolate -mt-16 overflow-hidden bg-gradient-to-b from-accent-300 to-brand-400">
    {page.data.heroImage && (
        <img
            src={withBase(page.data.heroImage)}
            alt=""
            aria-hidden="true"
            loading="eager"
            decoding="async"
            data-hero-parallax
            class="pointer-events-none absolute -top-[10%] left-0 -z-10 h-[120%] w-full object-cover opacity-20 mix-blend-multiply will-change-transform"
        />
    )}
    <div class="container-content pb-16 pt-32 lg:pb-24 lg:pt-40">
      <h1 class="text-3xl font-bold sm:text-4xl lg:text-5xl text-accent-50">{page.data.heroTitle}</h1>
      {page.data.heroSubtitle && <p class="mt-5 max-w-2xl text-lg text-accent-100">{page.data.heroSubtitle}</p>}
    </div>
  </section>

  <div class="container-content py-16">
    {
      [...groups.entries()].map(([category, items]) => (
        <section class="mt-12">
          {category && <h2 class="text-xl font-semibold text-brand-800">{category}</h2>}
          <ul class="mt-5 divide-y divide-slate-200 rounded-xl border border-slate-200">
            {items.map((s) => (
              <li class="flex flex-col gap-2 p-5 sm:flex-row sm:items-baseline sm:justify-between">
                <div class="sm:pr-8">
                  <h3 class="font-semibold">{s.data.name}</h3>
                  <p class="mt-1 text-sm text-slate-600">{s.data.description}</p>
                </div>
                {s.data.price && (
                  <p class="flex-none whitespace-nowrap text-sm font-semibold text-accent-600">
                    <span class="sr-only">{t('services.price')}: </span>
                    {s.data.price}
                  </p>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))
    }

    <p class="mt-10 text-sm text-slate-500">
      <a href={localePath(locale, 'contact')} class="text-brand-600 hover:text-brand-800">
        {t('nav.contact')} →
      </a>
    </p>
  </div>
</BaseLayout>

<script>
  // Small vertical parallax on the hero background image.
  // Respects prefers-reduced-motion and uses rAF to stay off the scroll thread.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const img = document.querySelector<HTMLImageElement>('[data-hero-parallax]');
  const section = img?.closest('section');

  if (img && section && !reduceMotion.matches) {
    const FACTOR = 0.2; // px moved per px scrolled (kept subtle)
    let ticking = false;

    const update = () => {
      ticking = false;
      const rect = section.getBoundingClientRect();
      // Only animate while the hero is in (or near) the viewport.
      if (rect.bottom < 0 || rect.top > window.innerHeight) return;
      const offset = Math.max(0, -rect.top) * FACTOR;
      img.style.transform = `translate3d(0, ${offset}px, 0)`;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    update();
  }
</script>
