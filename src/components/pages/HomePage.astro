---
import { render } from 'astro:content';
import { type Locale, useTranslations, localePath, LOCALES } from '@/lib/i18n';
import { getLocalizedEntry, getLocalized, getSettings } from '@/lib/content';
import BaseLayout from '@/layouts/BaseLayout.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const page = await getLocalizedEntry('pages', 'home', locale);
if (!page) throw new Error(`Missing pages/home.${locale}.md`);
const { Content } = await render(page);

const services = (await getLocalized('services', locale)).slice(0, 3);
const settings = await getSettings(locale);
const telHref = `tel:${settings.phone.replace(/\s+/g, '')}`;

const alternates = Object.fromEntries(LOCALES.map((l) => [l, localePath(l, 'home')])) as Record<
  Locale,
  string
>;
---

<BaseLayout
  locale={locale}
  title={page.data.seo?.title ?? page.data.title}
  description={page.data.seo?.description ?? ''}
  alternates={alternates}
>
  {/* Hero */}
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="container-content grid gap-8 py-16 lg:grid-cols-2 lg:items-center lg:py-24">
      <div>
        <h1 class="text-3xl font-bold sm:text-4xl lg:text-5xl">{page.data.heroTitle}</h1>
        <p class="mt-5 text-lg text-slate-600">{page.data.heroSubtitle}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={telHref} class="btn-primary">{t('cta.call')}: {settings.phone}</a>
          <a href={localePath(locale, 'services')} class="btn-outline">{t('nav.services')}</a>
        </div>
      </div>
      <div class="prose-clinic rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-100">
        <Content />
      </div>
    </div>
  </section>

  {/* Services preview */}
  <section class="container-content py-16">
    <h2 class="text-2xl font-bold">{t('nav.services')}</h2>
    <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <li class="rounded-xl border border-slate-200 p-6">
            <h3 class="text-lg font-semibold">{s.data.name}</h3>
            <p class="mt-2 text-sm text-slate-600">{s.data.description}</p>
            {s.data.price && (
              <p class="mt-3 text-sm font-semibold text-accent-600">{s.data.price}</p>
            )}
          </li>
        ))
      }
    </ul>
    <div class="mt-8">
      <a href={localePath(locale, 'services')} class="btn-outline">{t('nav.services')} →</a>
    </div>
  </section>
</BaseLayout>
