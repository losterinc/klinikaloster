---
import { type Locale, useTranslations, localePath, withBase, LOCALES } from '@/lib/i18n';
import { getLocalizedEntry, getAll, getSettings } from '@/lib/content';
import BaseLayout from '@/layouts/BaseLayout.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const page = await getLocalizedEntry('pages', 'home', locale);
if (!page) throw new Error(`Missing pages/home.${locale}.md`);

const services = (await getAll('services'))
    .filter(s => s.data.homepage)
    .slice(0, 3);
const indications = (await getAll('indications'))
    .filter(i => i.data.homepage);
const settings = await getSettings(locale);
const telHref = `tel:${settings.phone.replace(/\s+/g, '')}`;

const bookingWidgets = page.data.bookingWidgets ?? [];
const bookingTitle = page.data.bookingTitle ?? t('booking.title');

const alternates = Object.fromEntries(LOCALES.map((l) => [l, localePath(l, 'home')])) as Record<
  Locale,
  string
>;
---

<BaseLayout
  locale={locale}
  title={page.data.seo?.title ?? page.data.title}
  description={page.data.seo?.description ?? ''}
  alternates={alternates}
>
  <section class="relative isolate -mt-16 overflow-hidden bg-gradient-to-b from-accent-300 to-brand-400">
    {page.data.heroImage && (
        <img
            src={withBase(page.data.heroImage)}
            alt=""
            aria-hidden="true"
            loading="eager"
            decoding="async"
            data-hero-parallax
            class="pointer-events-none absolute -top-[10%] left-0 -z-10 h-[120%] w-full object-cover opacity-20 mix-blend-multiply will-change-transform"
        />
    )}
    <div class="container-content grid gap-8 pb-16 pt-32 lg:grid-cols-2 lg:items-center lg:pb-24 lg:pt-40">
      <div>
        <h1 class="text-3xl font-bold sm:text-4xl lg:text-5xl text-accent-50">{page.data.heroTitle}</h1>
        <p class="mt-5 text-lg text-accent-100">{page.data.heroSubtitle}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={telHref} class="btn-primary">{t('cta.call')}: {settings.phone}</a>
        </div>
      </div>
      {page.data.heroSecondaryImage && (
          <div class="hidden items-end justify-end self-end lg:-mb-24 lg:flex">
            <img
                src={withBase(page.data.heroSecondaryImage)}
                alt=""
                loading="eager"
                decoding="async"
                class="w-full max-w-md rounded-t-2xl object-cover"
            />
          </div>
      )}
    </div>
  </section>

  {/* Umów wizytę — ZnanyLekarz booking widgets (order = CMS list order) */}
  { bookingWidgets.length > 0 && (
      <section id="umow-wizyte" class="bg-white">
        <div class="container-content py-16">
          <h2 class="text-2xl font-bold">{bookingTitle}</h2>
          <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {
              bookingWidgets.map((w, idx) => (
                  <div class="relative h-[244px] w-full overflow-hidden rounded-lg" data-booking-widget>
                    {/* Skeleton loader — shown until the iframe fires its load event */}
                    <div
                        aria-hidden="true"
                        data-booking-skeleton
                        class="absolute inset-0 animate-pulse rounded-lg border border-slate-200 bg-white p-4"
                    >
                      <div class="flex items-center gap-3">
                        <div class="h-12 w-12 shrink-0 rounded-full bg-slate-200" />
                        <div class="flex-1 space-y-2">
                          <div class="h-3 w-2/3 rounded bg-slate-200" />
                          <div class="h-2.5 w-1/2 rounded bg-slate-100" />
                        </div>
                      </div>
                      <div class="mt-5 grid grid-cols-4 gap-2">
                        {Array.from({ length: 4 }).map(() => (
                            <div class="space-y-2">
                              <div class="h-2.5 rounded bg-slate-100" />
                              <div class="h-7 rounded bg-slate-200" />
                              <div class="h-7 rounded bg-slate-100" />
                            </div>
                        ))}
                      </div>
                    </div>
                    <iframe frameborder="0" scrolling="no" allowtransparency="true" data-id="qrpda9kpyz" title="Docplanner Booking Widget" src=`https://widgets.znanylekarz.pl/doctor/widget/big/${w.doctor}?customUtm=null&amp;id=qrpda9kpyz&amp;header=null&amp;content=null&amp;fullwidth=null&amp;referer=https%3A%2F%2Floster.pl%2F&amp;hide_branding=null&amp;widget_position=bottom&amp;opinion=false&amp;saasonly=false&amp;expand_calendar=false` style="border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; overflow: hidden; width: 100%; height: 244px;" class="relative h-full w-full opacity-0 transition-opacity duration-500 data-[loaded]:opacity-100"></iframe>
                  </div>

              ))
            }
          </div>
        </div>
      </section>
  )}

  {/* Indications preview */}
  { indications.length > 0 && (
      <section class="bg-brand-50">
        <div class="container-content py-16">
          <h2 class="text-2xl font-bold">{t('nav.indications')}</h2>

          {/* Carousel — buttons flank the track left/right, hidden until JS detects overflow */}
          <div class="relative mt-8">
            <button
                type="button"
                data-indications-prev
                aria-label={t('carousel.prev')}
                hidden
                class="absolute left-0 top-1/2 z-10 flex h-11 w-11 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-brand-300 bg-white text-brand-700 shadow-md transition hover:bg-brand-100 disabled:cursor-not-allowed disabled:opacity-0 max-sm:left-2 max-sm:-translate-x-0"
            >
              <span aria-hidden="true">←</span>
            </button>
            <ul
                data-indications-track
                class="flex snap-x snap-mandatory gap-6 overflow-hidden scroll-smooth py-8 -my-8"
            >
            {
              indications.map((i) => (
                  <li class="group relative flex min-h-[22rem] w-full shrink-0 snap-start flex-col justify-end overflow-hidden rounded-xl bg-brand-700 shadow-sm transition duration-500 ease-out hover:-translate-y-2 hover:shadow-2xs sm:w-[20rem]">
                    {i.data.image && (
                        <img
                            src={withBase(i.data.image)}
                            alt=""
                            loading="lazy"
                            decoding="async"
                            class="absolute inset-0 h-full w-full object-cover grayscale transition duration-700 ease-out group-hover:scale-105 group-hover:grayscale-0"
                        />
                    )}
                    {/* Desaturated brand-gradient multiply tint — fades out on hover to reveal the original colours */}
                    <div
                        aria-hidden="true"
                        class="pointer-events-none absolute inset-0 bg-gradient-to-b from-brand-400 to-emerald-700 opacity-80 mix-blend-multiply transition-opacity duration-500 group-hover:opacity-0"
                    />
                    {/* Bottom scrim keeps the text readable over the image */}
                    <div
                        aria-hidden="true"
                        class="pointer-events-none absolute inset-x-0 bottom-0 top-1/3 bg-gradient-to-t from-black/80 via-black/40 to-transparent"
                    />
                    <div class="relative p-6">
                      <h3 class="text-lg font-semibold text-white drop-shadow-sm">{i.data.title}</h3>
                      {i.data.summary && (
                          <p class="mt-2 text-sm text-white/85 drop-shadow-sm">{i.data.summary}</p>
                      )}
                    </div>
                  </li>
              ))
            }
            </ul>
            <button
                type="button"
                data-indications-next
                aria-label={t('carousel.next')}
                hidden
                class="absolute right-0 top-1/2 z-10 flex h-11 w-11 translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-brand-300 bg-white text-brand-700 shadow-md transition hover:bg-brand-100 disabled:cursor-not-allowed disabled:opacity-0 max-sm:right-2 max-sm:translate-x-0"
            >
              <span aria-hidden="true">→</span>
            </button>
          </div>

          <div class="mt-8">
            <a href={localePath(locale, 'indications')} class="btn-outline">{t('nav.full_indications')} →</a>
          </div>
        </div>
      </section>
  )}

  {/* Services preview */}
  { services.length > 0 && (
      <section class="container-content py-16">
        <h2 class="text-2xl font-bold">{t('nav.services')}</h2>
        <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            services.map((s) => (
                <li class="rounded-xl border border-slate-200 p-6">
                  <h3 class="text-lg font-semibold">{s.data.name}</h3>
                  <p class="mt-2 text-sm text-slate-600">{s.data.description}</p>
                  {s.data.price && (
                      <p class="mt-3 text-sm font-semibold text-accent-600">{s.data.price}</p>
                  )}
                </li>
            ))
          }
        </ul>
        <div class="mt-8">
          <a href={localePath(locale, 'services')} class="btn-outline">{t('nav.full_services')} →</a>
        </div>
      </section>
  )}

  {/* ZnanyLekarz widget loader — turns every .zl-url anchor into a booking widget.
      `is:inline` keeps Astro from bundling it so the third-party script runs as-is. */}
  { bookingWidgets.length > 0 && (
      <script is:inline>
        {`(function(d,s,id){if(d.getElementById(id))return;var js=d.createElement(s);js.id=id;js.src="https://platform.docplanner.com/js/widget.min.js";var fjs=d.getElementsByTagName(s)[0];fjs.parentNode.insertBefore(js,fjs);})(document,"script","zl-widget-s");`}
      </script>
  )}
</BaseLayout>

<script>
  // Booking widgets — reveal each iframe and drop its skeleton once it loads.
  const widgets = document.querySelectorAll<HTMLElement>('[data-booking-widget]');
  widgets.forEach((widget) => {
    const iframe = widget.querySelector<HTMLIFrameElement>('iframe');
    const skeleton = widget.querySelector<HTMLElement>('[data-booking-skeleton]');
    if (!iframe) return;

    let revealed = false;
    // Wait until the iframe is fully loaded, then give the widget content a
    // moment to paint before fading out the skeleton.
    const reveal = () => {
      if (revealed) return;
      revealed = true;
      setTimeout(() => {
        iframe.setAttribute('data-loaded', '');
        skeleton?.remove();
      }, 1500);
    };

    // `load` may have already fired before hydration; reveal anyway as a fallback.
    iframe.addEventListener('load', reveal, { once: true });
    if (iframe.contentDocument?.readyState === 'complete') reveal();
  });
</script>

<script>
  // Small vertical parallax on the hero background image.
  // Respects prefers-reduced-motion and uses rAF to stay off the scroll thread.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const img = document.querySelector<HTMLImageElement>('[data-hero-parallax]');
  const section = img?.closest('section');

  if (img && section && !reduceMotion.matches) {
    const FACTOR = 0.2; // px moved per px scrolled (kept subtle)
    let ticking = false;

    const update = () => {
      ticking = false;
      const rect = section.getBoundingClientRect();
      // Only animate while the hero is in (or near) the viewport.
      if (rect.bottom < 0 || rect.top > window.innerHeight) return;
      const offset = Math.max(0, -rect.top) * FACTOR;
      img.style.transform = `translate3d(0, ${offset}px, 0)`;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    update();
  }
</script>

<script>
  // Indications carousel — horizontal scroll with prev/next buttons that flank the track.
  // Buttons step one card at a time and stay hidden unless the track overflows.
  const track = document.querySelector<HTMLUListElement>('[data-indications-track]');
  const prevBtn = document.querySelector<HTMLButtonElement>('[data-indications-prev]');
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-indications-next]');

  if (track && prevBtn && nextBtn) {
    // One card width + the flex gap, so each click advances by exactly one card.
    const step = () => {
      const card = track.querySelector<HTMLElement>(':scope > li');
      if (!card) return track.clientWidth;
      const gap = parseFloat(getComputedStyle(track).columnGap) || 0;
      return card.offsetWidth + gap;
    };

    const updateState = () => {
      const max = track.scrollWidth - track.clientWidth;
      const hasOverflow = max > 1;
      // Hide a button when it can't move any further (and when nothing overflows).
      prevBtn.hidden = !hasOverflow || track.scrollLeft <= 1;
      nextBtn.hidden = !hasOverflow || track.scrollLeft >= max - 1;
    };

    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -step(), behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: step(), behavior: 'smooth' });
    });

    track.addEventListener('scroll', updateState, { passive: true });
    window.addEventListener('resize', updateState);
    updateState();
  }
</script>
