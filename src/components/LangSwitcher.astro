---
import { ACTIVE_LOCALES, type Locale, useTranslations } from '@/lib/i18n';

interface Props {
  locale: Locale;
  /** Map of locale -> path for the equivalent page in that locale. */
  alternates: Record<Locale, string>;
}

const { locale, alternates } = Astro.props;
// Only offer to switch to another *active* (publicly visible) locale. With a
// single active locale the switcher renders nothing.
const other = ACTIVE_LOCALES.find((l) => l !== locale && alternates[l]);
const t = useTranslations(locale);
---

{
  other && (
    <a
      href={alternates[other]}
      hreflang={other}
      class="text-sm font-medium text-brand-700 hover:text-brand-900"
      aria-label={t('lang.switch')}
    >
      {t('lang.switch')}
    </a>
  )
}
