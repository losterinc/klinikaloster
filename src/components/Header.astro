---
import { type Locale, useTranslations, localePath } from '@/lib/i18n';
import LangSwitcher from './LangSwitcher.astro';
import {withBase} from "../lib/i18n";

interface Props {
  locale: Locale;
  clinicName: string;
  clinicLogoImage?: string;
  facebookUrl?: string;
  alternates: Record<Locale, string>;
}

const { locale, clinicName, clinicLogoImage, facebookUrl, alternates } = Astro.props;
const t = useTranslations(locale);

const nav = [
  { href: localePath(locale, 'services'), label: t('nav.services') },
  { href: localePath(locale, 'indications'), label: t('nav.indications') },
  { href: localePath(locale, 'team'), label: t('nav.team') },
  { href: localePath(locale, 'contact'), label: t('nav.contact') },
];

const current = Astro.url.pathname;
const isActive = (href: string) => current === href || current === href.replace(/\/$/, '');
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-brand-50/70 backdrop-blur-sm">
  <div class="container-content flex h-16 items-center justify-between gap-4" data-header-inner>
    <a href={localePath(locale, 'home')} class="flex min-w-0 items-center gap-3 font-serif text-lg font-bold text-brand-800" data-header-logo>
      {clinicLogoImage && (
          <img
              src={withBase(clinicLogoImage)}
              alt="Logo Kliniki"
              width={42}
              height={42}
              loading="lazy"
              decoding="async"
              class="h-12 w-12 flex-none object-contain"
          />
      )}
      <span class="whitespace-nowrap">{clinicName}</span>
    </a>

    <nav aria-label="Główna nawigacja" class="hidden shrink-0 items-center gap-6 md:flex" data-desktop-nav>
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'whitespace-nowrap rounded-full px-8 py-2 border border-brand-100 text-center text-sm font-medium transition-colors hover:bg-white/80 bg-white/20 backdrop-blur-sm',
              isActive(item.href) ? '' : '',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <LangSwitcher locale={locale} alternates={alternates} />
      {facebookUrl && (
        <a
          href={facebookUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="flex h-10 w-10 flex-none items-center justify-center rounded-full border border-brand-100 bg-white/20 text-brand-800 backdrop-blur-sm transition-colors hover:bg-white/80"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
          </svg>
        </a>
      )}
    </nav>

    <!-- Mobile / overflow: native disclosure, no JS required -->
    <details class="relative md:hidden" data-mobile-nav>
      <summary
        class="flex cursor-pointer items-center rounded-md p-2 text-slate-700 marker:content-none [&::-webkit-details-marker]:hidden"
        aria-label="Menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7" /><line x1="4" y1="12" x2="20" y2="12" /><line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </summary>
      <div class="absolute right-0 mt-2 w-56 rounded-lg border border-slate-200 bg-white p-2 shadow-lg">
        {
          nav.map((item) => (
            <a href={item.href} class="block rounded-md px-3 py-2 text-sm text-slate-700 hover:bg-brand-50">
              {item.label}
            </a>
          ))
        }
        <div class="mt-1 border-t border-slate-100 px-3 py-2">
          <LangSwitcher locale={locale} alternates={alternates} />
        </div>
        {facebookUrl && (
          <a
            href={facebookUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 rounded-md px-3 py-2 text-sm text-slate-700 hover:bg-brand-50"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
            Facebook
          </a>
        )}
      </div>
    </details>
  </div>
</header>

<style>
  /* When JS detects the desktop nav would overflow, force the hamburger,
     overriding the md: breakpoint baseline. */
  [data-header-inner].nav-force-compact [data-desktop-nav] {
    display: none !important;
  }
  [data-header-inner].nav-force-compact [data-mobile-nav] {
    display: block !important;
  }
</style>

<script>
  // Collapse the desktop nav into the hamburger whenever it would overflow,
  // regardless of viewport width (label/clinic-name length varies per locale).
  // The md: breakpoint in the markup is the no-JS fallback.
  function setupHeader() {
    const inner = document.querySelector<HTMLElement>('[data-header-inner]');
    if (!inner) return;
    const logo = inner.querySelector<HTMLElement>('[data-header-logo]');
    const nav = inner.querySelector<HTMLElement>('[data-desktop-nav]');
    if (!logo || !nav) return;

    // Capture into non-null locals so narrowing holds inside the closures below.
    const innerEl = inner;
    const logoEl = logo;
    const navEl = nav;
    let scheduled = false;

    function measure() {
      scheduled = false;
      // Reset so the media-query baseline applies while we measure.
      innerEl.classList.remove('nav-force-compact');

      // Below md the desktop nav is display:none — the native mobile menu
      // already handles it, and we can't measure a hidden element.
      if (getComputedStyle(navEl).display === 'none') return;

      // scrollWidth reports each child's full content width even if flex
      // shrinks the box; +16px accounts for the gap-4 between logo and nav.
      const needed = logoEl.scrollWidth + navEl.scrollWidth + 16;
      if (needed > innerEl.clientWidth) {
        innerEl.classList.add('nav-force-compact');
      }
    }

    function schedule() {
      if (scheduled) return;
      scheduled = true;
      requestAnimationFrame(measure);
    }

    new ResizeObserver(schedule).observe(innerEl);
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(schedule);
    }
    schedule();
  }

  setupHeader();
  // Re-run after view transitions / client-side navigation.
  document.addEventListener('astro:after-swap', setupHeader);
</script>
