---
import { type Locale, useTranslations, localePath } from '@/lib/i18n';

interface Settings {
  clinicName: string;
  address: { street: string; postalCode: string; city: string };
  phone: string;
  sms?: string;
  email: string;
  openingHours: { days: string; hours: string }[];
}

interface Props {
  locale: Locale;
  settings: Settings;
}

const { locale, settings } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
const telHref = `tel:${settings.phone.replace(/\s+/g, '')}`;
const smsHref = settings.sms ? `sms:${settings.sms.replace(/\s+/g, '')}` : undefined;
---

<footer class="mt-20 border-t border-slate-200 bg-slate-50">
  <div class="container-content grid gap-10 py-12 sm:grid-cols-2 lg:grid-cols-3">
    <div>
      <h2 class="text-base font-semibold text-brand-900">{settings.clinicName}</h2>
      <address class="mt-3 not-italic text-sm leading-relaxed text-slate-600">
        {settings.address.street}<br />
        {settings.address.postalCode} {settings.address.city}
      </address>
    </div>

    <div>
      <h2 class="text-base font-semibold text-brand-900">{t('nav.contact')}</h2>
      <ul class="mt-3 space-y-1 text-sm text-slate-600">
        <li><a class="hover:text-brand-700" href={telHref}>tel. {settings.phone}</a></li>
        {smsHref && <li><a class="hover:text-brand-700" href={smsHref}>sms {settings.sms}</a></li>}
        <li><a class="hover:text-brand-700" href={`mailto:${settings.email}`}>{settings.email}</a></li>
      </ul>
    </div>

    <div>
      <h2 class="text-base font-semibold text-brand-900">{t('contact.hours')}</h2>
      <ul class="mt-3 space-y-1 text-sm text-slate-600">
        {
          settings.openingHours.map((h) => (
            <li>
              <span class="font-medium text-slate-700">{h.days}</span>: {h.hours}
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-slate-200">
    <div class="container-content flex flex-col gap-2 py-5 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {settings.clinicName}. {t('footer.rights')}.</p>
      <a href={localePath(locale, 'home')} class="hover:text-brand-700">{t('nav.home')}</a>
    </div>
  </div>
</footer>
